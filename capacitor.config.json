{
  "appId": "com.naanocorp.planner",
  "appName": "SpherePlan",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": false
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "androidSpinnerStyle": "small"
    }
  }
}
